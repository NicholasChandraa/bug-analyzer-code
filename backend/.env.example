DATABASE_URL=postgresql://user:password@localhost:5432/restack_pattern
JWT_SECRET=your-secret-key-min-32-characters  # your-secret-key-min-32-characters
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000,https://myapp.vercel.app
# COOKIE_SAME_SITE=Lax   # override default (None in production, Lax in development)
# COOKIE_DOMAIN=.example.com   # only set if FE/BE share a domain, e.g. app.example.com + api.example.com
#                              # see docs/deployment-verification.md before deploying cross-domain
# LOG_FILE_PATH=logs/app.log   # Optional log file path (outputs to stdout and writes to this file)

# LLM Gateway - provider apa aja yang ngomong format Chat Completions ala-OpenAI bisa dipakai.
LLM_API_KEY=your-provider-api-key
# LLM_BASE_URL=https://ai.sumopod.com/v1  # contoh SumoPod; kosongkan kalau pakai OpenAI resmi
# contoh lain: https://openrouter.ai/api/v1 (OpenRouter)
# contoh lain: https://generativelanguage.googleapis.com/v1beta/openai (Gemini)
# contoh lain: https://api.anthropic.com/v1 (Claude, via OpenAI-compat endpoint)
LLM_MODEL=gpt-4o-mini