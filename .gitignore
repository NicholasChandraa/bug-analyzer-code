# Dependencies (Abaikan node_modules di folder mana pun)
**/node_modules/

# Next.js build output (Abaikan .next di folder mana pun)
**/.next/
**/out/

# Build outputs
**/dist/
**/build/
**/.output/

# Env files (Abaikan semua file env di folder mana pun)
**/.env*
**/*.env
!**/.env.example

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# OS Files
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

# Claude Code local overrides (personal, not shared with the team)
.claude/settings.local.json
test-project/
test-app/

# Exclude concerns from git
docs/concerns.md

docs/tutorial.md
